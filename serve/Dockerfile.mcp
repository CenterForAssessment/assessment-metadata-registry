# Thin MCP server over the registry SQLite projection (Tier C, ADR-012).
# The DB is NOT baked in — it is bind-mounted read-only at runtime (see docker-compose.yml),
# keeping the image disposable/regenerable and the data out of the layer cache.
FROM python:3.12-slim

# sqlite3 ships with Python; no OS SQLite CLI needed inside this image.
WORKDIR /app

COPY mcp/pyproject.toml /app/pyproject.toml
RUN pip install --no-cache-dir "mcp>=1.28,<2"

COPY mcp/ /app/

ENV AMRR_REGISTRY_DB=/data/registry.sqlite \
    MCP_TRANSPORT=streamable-http \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=8010

EXPOSE 8010
CMD ["python", "server.py"]
